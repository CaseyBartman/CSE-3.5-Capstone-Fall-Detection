{
  "version": 1,
  "author": "Casey Bartman",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    {
      "type": "wokwi-slide-potentiometer",
      "id": "pot1",
      "top": -129.4,
      "left": -202.6,
      "attrs": {}
    },
    {
      "type": "wokwi-pushbutton",
      "id": "btn1",
      "top": 100,
      "left": -150,
      "attrs": { "color": "blue" }
    }
  ],
  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],
    [ "esp:GND.1", "pot1:GND", "black", [ "v0" ] ],
    [ "esp:3V3.1", "pot1:VCC", "red", [ "v0" ] ],
    [ "pot1:SIG", "esp:34", "green", [ "v0" ] ],
    [ "btn1:1.L", "esp:15", "green", [ "v0" ] ],
    [ "btn1:2.L", "esp:GND.2", "black", [ "v0" ] ]
  ],
  "serialMonitor": { "convertEol": true, "display": "always" },
  "dependencies": {}
}